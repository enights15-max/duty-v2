APP_NAME="Duty Tickets"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio.com
APP_TIMEZONE=America/Santo_Domingo

LOG_CHANNEL=stack
LOG_LEVEL=error

# ============================================================
# Base de datos
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=duty_db
DB_USERNAME=duty_user
DB_PASSWORD=

# ============================================================
# Cache / Queue / Session
# ============================================================
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# Email
# ============================================================
MAIL_DRIVER=smtp
MAIL_HOST=mail.tu-dominio.com
MAIL_PORT=587
MAIL_USERNAME=tickets@tu-dominio.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=TLS
MAIL_FROM_ADDRESS=tickets@tu-dominio.com
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# Stripe (requerido)
# ============================================================
STRIPE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXX
STRIPE_SECRET=sk_live_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# ============================================================
# Web Push (VAPID)
# ============================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ============================================================
# Pusher (notificaciones en tiempo real)
# ============================================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ============================================================
# Pasarelas de pago opcionales
# ============================================================

# Mollie
MOLLIE_KEY=

# Authorize.net
ANET_API_LOGIN_ID=
ANET_TRANSACTION_KEY=
ANET_PUBLIC_CLIENT_KEY=

# Paytm
PAYTM_ENVIRONMENT=production
PAYTM_MERCHANT_KEY=
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_WEBSITE=
PAYTM_INDUSTRY_TYPE=

# Xendit
XENDIT_SECRET_KEY=

# Flutterwave
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=

# MyFatoorah
MYFATOORAH_TOKEN=
MYFATOORAH_CALLBACK_URL=https://tu-dominio.com/myfatoorah/callback
MYFATOORAH_ERROR_URL=https://tu-dominio.com/myfatoorah/cancel
