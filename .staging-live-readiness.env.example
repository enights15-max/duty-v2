# Copy this file to:
#   .staging-live-readiness.env
#
# Then run:
#   ./scripts/security/staging-live-readiness-from-file.sh --check-only
#   ./scripts/security/staging-live-readiness-from-file.sh

DUTY_STAGING_BASE_URL=https://staging.example.com
DUTY_STAGING_ENV_FILE=.env

# Use token OR username/password
DUTY_STAGING_AUTH_TOKEN=
DUTY_STAGING_AUTH_USERNAME=
DUTY_STAGING_AUTH_PASSWORD=

DUTY_STAGING_AUTH_DEVICE_NAME=staging-readiness-window
DUTY_STAGING_IDENTITY_ID=
DUTY_STAGING_TOPUP_AMOUNT=25
DUTY_STAGING_FINAL_SCOPE=stripe
DUTY_STAGING_REPORT_DIR=
DUTY_STAGING_BOARD_OUTPUT=
DUTY_STAGING_BOARD_TITLE=Staging Live Go/No-Go Board
DUTY_STAGING_ALLOW_PUBLIC_BASE_URL=1
